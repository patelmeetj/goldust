<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <system.webServer>

    <httpErrors>
      <remove statusCode="400" />
      <error statusCode="400" path="C:\Inetpub\vhosts\goldust.in\error_docs\bad_request.html" />
      <remove statusCode="401" />
      <error statusCode="401" path="C:\Inetpub\vhosts\goldust.in\error_docs\unauthorized.html" />
      <remove statusCode="403" />
      <error statusCode="403" path="C:\Inetpub\vhosts\goldust.in\error_docs\forbidden.html" />
      <remove statusCode="404" />
      <error statusCode="404" path="C:\Inetpub\vhosts\goldust.in\error_docs\not_found.html" />
      <remove statusCode="405" />
      <error statusCode="405" path="C:\Inetpub\vhosts\goldust.in\error_docs\method_not_allowed.html" />
      <remove statusCode="406" />
      <error statusCode="406" path="C:\Inetpub\vhosts\goldust.in\error_docs\not_acceptable.html" />
      <remove statusCode="407" />
      <error statusCode="407" path="C:\Inetpub\vhosts\goldust.in\error_docs\proxy_authentication_required.html" />
      <remove statusCode="412" />
      <error statusCode="412" path="C:\Inetpub\vhosts\goldust.in\error_docs\precondition_failed.html" />
      <remove statusCode="414" />
      <error statusCode="414" path="C:\Inetpub\vhosts\goldust.in\error_docs\request-uri_too_long.html" />
      <remove statusCode="415" />
      <error statusCode="415" path="C:\Inetpub\vhosts\goldust.in\error_docs\unsupported_media_type.html" />
      <remove statusCode="500" />
      <error statusCode="500" path="C:\Inetpub\vhosts\goldust.in\error_docs\internal_server_error.html" />
      <remove statusCode="501" />
      <error statusCode="501" path="C:\Inetpub\vhosts\goldust.in\error_docs\not_implemented.html" />
      <remove statusCode="502" />
      <error statusCode="502" path="C:\Inetpub\vhosts\goldust.in\error_docs\bad_gateway.html" />
      <remove statusCode="503" />
      <error statusCode="503" path="C:\Inetpub\vhosts\goldust.in\error_docs\maintenance.html" />
    </httpErrors>

    <tracing>
      <traceFailedRequests>
        <clear />
      </traceFailedRequests>
    </tracing>

    <rewrite>
      <rules>

        <rule name="Project ASPX to HTML" stopProcessing="true">
          <match url="^project\.aspx$" ignoreCase="true" />
          <action type="Redirect" url="/project.html" redirectType="Permanent" />
        </rule>

        <rule name="Contact ASPX to HTML" stopProcessing="true">
          <match url="^ContactUs\.aspx$" ignoreCase="true" />
          <action type="Redirect" url="/contact.html" redirectType="Permanent" />
        </rule>

      </rules>
    </rewrite>

  </system.webServer>

  <system.web>
    <compilation tempDirectory="C:\Inetpub\vhosts\goldust.in\tmp" />
  </system.web>

</configuration>